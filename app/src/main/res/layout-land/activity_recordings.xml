<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".RecordingsActivity">

    <TextView
        android:id="@+id/recordings_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recordings"
        android:textColor="@color/purple_700"
        android:textSize="28sp"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/recordings_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="24dp" />

    <!-- Playback controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/button_play_pause_replay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/nav_bar_background"
            android:text="Play"
            android:textAllCaps="false"
            android:textColor="@color/text_on_purple"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/recording_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="8dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_purple_horizontal" />
    </LinearLayout>

    <Button
        android:id="@+id/button_back_to_main"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/nav_bar_background"
        android:text="Back to Main"
        android:textAllCaps="false"
        android:textColor="@color/text_on_purple"
        android:textStyle="bold" />

</LinearLayout>

